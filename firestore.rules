rules_version = '2';

// This app uses: leads, properties, users, teamMembers
// You MUST publish these rules in Firebase Console (Firestore → Rules) or run:
//   firebase deploy --only firestore:rules
// (Copy .firebaserc.example to .firebaserc and set your project id.)

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Any signed-in staff (same as "authenticated" for this CRM)
    function isStaff() {
      return isAuthenticated();
    }

    // 1. Leads — dashboard, list, detail, pipeline
    match /leads/{leadId} {
      allow read, write: if isAuthenticated();
    }

    // 2. Properties — inventory list
    match /properties/{propertyId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    // 3. Users — login sync (setDoc merge on own uid)
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isOwner(userId);
    }

    // 4. Team — login reads own doc by email id; team page lists all members
    // "read" covers both get (single doc) and list (collection queries).
    match /teamMembers/{emailId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }
    
    // Fallback: Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
